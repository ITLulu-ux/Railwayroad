    <select id="selectDailyStats" parameterType="directory.my.db.dto.StatsSearchDto" resultType="directory.my.db.dto.StatsResultDto">
        SELECT
        STAT_DATE AS statDate,
        TOTAL_GET_IN AS totalGetIn,
        TOTAL_GET_OFF AS totalGetOff,
        TOTAL_GET_IN - TOTAL_GET_OFF AS netGetIn,
        AVG_ON_BOARD AS avgOnBoard,
        ROUTE_NM AS routeNm
        FROM DAILY_LOG_STATS
        WHERE STAT_DATE >= TO_DATE(#{startDate}, 'YYYY-MM-DD')
        AND STAT_DATE &lt; TO_DATE(#{endDate}, 'YYYY-MM-DD')+1
        <if test="routeNm !=null and routeNm !=''">
            AND ROUTE_NM = #{routeNm}
        </if>
        ORDER BY statDate;
    </select>


    <select id="selectWeeklyStats" parameterType="directory.my.db.dto.StatsSearchDto" resultType="directory.my.db.dto.StatsResultDto">
        SELECT
        DATE_TRUNC('WEEK', STAT_DATE) AS statDate,
        SUM(TOTAL_GET_IN) AS totalGetIn,
        SUM(TOTAL_GET_OFF) AS totalGetOff,
        SUM(TOTAL_GET_IN - TOTAL_GET_OFF) AS netGetIn,
        SUM(AVG_ON_BOARD) AS avgOnBoard,
        ROUTE_NM AS routeNm
        FROM DAILY_LOG_STATS
        WHERE STAT_DATE >= TO_DATE(#{startDate}, 'YYYY-MM-DD')
        AND STAT_DATE &lt; TO_DATE(#{endDate}, 'YYYY-MM-DD') + 1
        <if test="routeNm !=null and routeNm !=''">
            AND ROUTE_NM = #{routeNm}
        </if>
        GROUP BY DATE_TRUNC('WEEK', STAT_DATE),
        ROUTE_NM
        ORDER BY statDate;
    </select>

