<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org/DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="directory.my.db.mapper.AutoMapper">

    <select id="high_speed_line" resultType="directory.my.db.dto.AutoDto">
        SELECT (*) FROM stations a
        LEFT JOIN high_speed_lines b
        ON a.station_id = b.station_id
        WHERE 1=1
    </select>
